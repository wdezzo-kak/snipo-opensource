{
  "manifest_version": 3,
  "name": "Snipo Open",
  "version": "0.1.0",
  "description": "Open-source privacy-first Chrome Extension for active learning",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "commands"
  ],
  "host_permissions": [
    "https://*.coursera.org/*",
    "https://*.youtube.com/*"
  ],
  "action": {
    "default_title": "Snipo Open",
    "default_icon": {
      "16": "icon.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.coursera.org/*",
        "https://*.youtube.com/*"
      ],
      "js": [
        "content.js",
        "injected.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "https://*.coursera.org/*",
        "https://*.youtube.com/*"
      ]
    }
  ],
  "commands": {
    "time": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Add timestamp note"
    },
    "screen": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "Command+Shift+Period"
      },
      "description": "Take screenshot"
    },
    "pause": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Play/Pause video"
    },
    "transcript": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Toggle transcript"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}